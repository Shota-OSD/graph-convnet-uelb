{
    "_comment_meta": "=== GNN-ILS: GNN-guided Iterated Local Search (NSFNet, 30 commodities) ===",
    "expt_name": "gnn_ils_nsfnet_c30",
    "dataset_name": "nsfnet_c30",
    "gpu_id": "0",
    "use_gpu": false,

    "_comment_data": "=== Data Configuration ===",
    "solver_type": "pulp",
    "solver_time_limit": 60,
    "require_optimal": true,
    "graph_model": "nsfnet",
    "num_train_data": 3200,
    "num_val_data": 320,
    "num_test_data": 320,
    "num_nodes": 14,
    "num_commodities": 30,
    "sample_size": 30,
    "capacity_lower": 500,
    "capacity_higher": 2500,
    "demand_lower": 5,
    "demand_higher": 165,

    "_comment_model": "=== Model Architecture ===",
    "hidden_dim": 128,
    "num_layers": 4,
    "aggregation": "mean",
    "encoder_dropout_rate": 0.0,
    "mlp_dropout_rate": 0.0,

    "_comment_selector": "=== Selector Networks ===",
    "commodity_selector_mlp_layers": 3,
    "path_selector_mlp_layers": 3,
    "value_head_mlp_layers": 3,
    "use_graph_embedding_value": true,

    "_comment_path_pool": "=== Path Pool Configuration ===",
    "K": 10,
    "max_disjoint": 5,
    "max_candidate_paths": 15,

    "_comment_ils": "=== ILS Configuration ===",
    "max_iterations": 50,
    "no_improve_patience": 10,
    "perturbation_prob": 0.7,
    "max_perturbations": 4,

    "_comment_rl": "=== RL Algorithm (A2C / PPO) ===",
    "normalize_returns": true,
    "return_norm_momentum": 0.99,
    "_comment_critic_stability": "=== Critic Stability ===",
    "value_head_bias_init": 0.0,
    "warmup_epochs": 0,

    "_comment_ppo": "=== PPO Configuration ===",
    "use_ppo": true,
    "ppo_clip_eps": 0.15,
    "ppo_update_epochs": 3,
    "_ppo_update_epochs_note": "start=1, increase if clip_frac stays < 0.1",

    "entropy_weight_l1": 0.015,
    "entropy_weight_l2": 0.008,
    "_entropy_note": "L1 (C択) は探索空間が小さいため大きめ、L2 (パス択) は小さめ",
    "value_loss_weight": 0.5,
    "gamma": 0.95,
    "reward_scale": 15,
    "normalize_advantages": true,
    "grad_clip_norm": 0.5,
    "reward_mode": "shared",

    "_comment_training": "=== Training Configuration ===",
    "max_epochs": 120,
    "val_every": 5,
    "batch_size": 1,
    "_batch_size_note": "ILS は1サンプルずつ改善ループを回す",
    "samples_per_epoch": 200,
    "_samples_per_epoch_note": "1エポックあたりの処理サンプル数",
    "learning_rate": 0.0002,
    "decay_rate": 1.2,
    "lr_scheduler": "step",
    "weight_decay": 0.0001,
    "adam_beta1": 0.9,
    "adam_beta2": 0.999,

    "_comment_logging": "=== Logging and Checkpointing ===",
    "log_every": 10,
    "save_every": 10,
    "save_best_only": true,
    "tensorboard_dir": "runs/gnn_ils/",

    "_comment_eval": "=== Evaluation ===",
    "eval_deterministic": true,

    "_comment_debug": "=== Debug Options ===",
    "debug_mode": false,
    "verbose": true
}
